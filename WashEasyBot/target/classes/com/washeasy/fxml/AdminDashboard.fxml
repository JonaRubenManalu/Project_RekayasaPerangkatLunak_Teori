<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox fx:id="rootPane" prefHeight="680" prefWidth="1000" styleClass="root-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.washeasy.controller.AdminDashboardController">

    <!-- ══ NAVBAR ══ -->
    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="navbar">
        <padding><Insets bottom="0" left="20" right="20" top="0" /></padding>
        <Label prefHeight="32.0" prefWidth="59.0" style="-fx-font-size:22px;" />
      <ImageView fitHeight="63.0" fitWidth="108.0">
         <image>
            <Image url="@../images/logo.png" />
         </image>
      </ImageView>
        <VBox spacing="0">
            <Label styleClass="nav-brand" text="WashEasy" />
            <Label styleClass="nav-sub" text="ADMIN PANEL" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblUsername" styleClass="nav-user" text="Admin" />
        <Button onAction="#handleLogout" styleClass="btn-logout" text="Logout" />
    </HBox>

    <!-- ══ HERO BANNER ══ -->
    <HBox alignment="CENTER_LEFT" styleClass="hero-banner">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Text fx:id="txtWelcome" styleClass="hero-title" text="Selamat Datang Admin di WashEasy 👋" wrappingWidth="239.0382843017578" />
            <Label styleClass="hero-sub-text" text="Kelola informasi layanan laundry dengan mudah" />
        </VBox>
    </HBox>


    <HBox spacing="12" style="-fx-padding:16 24 8 24;">
        <VBox maxWidth="Infinity" prefHeight="100.0" prefWidth="124.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-label" text="Total Layanan" />
            <Label fx:id="lblTotalLayanan" styleClass="stat-value" text="0" />
        </VBox>
        <VBox maxWidth="Infinity" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-label" text="Layanan Aktif" />
            <Label fx:id="lblLayananAktif" styleClass="stat-value" text="0" />
        </VBox>
    </HBox>


    <HBox spacing="16" style="-fx-padding:0 24 20 24;" VBox.vgrow="ALWAYS">


        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="section-title" text="Data Layanan Laundry" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleTambah" styleClass="btn-primary" text="+ Tambah" />
                <Button onAction="#handleHapus" styleClass="btn-danger" text="Hapus" />
            </HBox>

            <TableView fx:id="tblLayanan" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="40" text="ID" />
                    <TableColumn fx:id="colNama" prefWidth="160" text="Nama Layanan" />
                    <TableColumn fx:id="colDeskripsi" prefWidth="200" text="Deskripsi" />
                    <TableColumn fx:id="colHarga" prefWidth="100" text="Harga" />
                    <TableColumn fx:id="colSatuan" prefWidth="70" text="Satuan" />
                    <TableColumn fx:id="colEstimasi" prefWidth="90" text="Estimasi" />
                </columns>
                <placeholder>
                    <Label styleClass="text-muted" text="Belum ada data layanan." />
                </placeholder>
            </TableView>
        </VBox>


        <VBox prefWidth="260" spacing="10" styleClass="form-card">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
            <Label styleClass="form-card-title" text="Form Layanan" />

            <Label styleClass="input-label" text="Nama Layanan *" />
            <TextField fx:id="fldNama" promptText="cth: Laundry Reguler" styleClass="form-input" />

            <Label styleClass="input-label" text="Deskripsi" />
            <TextField fx:id="fldDeskripsi" promptText="Deskripsi singkat" styleClass="form-input" />

            <Label styleClass="input-label" text="Harga (Rp) *" />
            <TextField fx:id="fldHarga" promptText="cth: 7000" styleClass="form-input" />

            <Label styleClass="input-label" text="Satuan *" />
            <ComboBox fx:id="cmbSatuan" maxWidth="Infinity" styleClass="form-input" />

            <Label styleClass="input-label" text="Estimasi Waktu *" />
            <TextField fx:id="fldEstimasi" promptText="cth: 2-3 hari" styleClass="form-input" />

            <Label fx:id="lblFormStatus" styleClass="status-label" text="" wrapText="true" />

            <HBox spacing="8">
                <Button fx:id="btnBatal" maxWidth="Infinity" onAction="#handleBatal" styleClass="btn-secondary" text="Batal" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnSimpan" maxWidth="Infinity" onAction="#handleSimpan" styleClass="btn-primary" text="Simpan" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

    </HBox>

</VBox>
